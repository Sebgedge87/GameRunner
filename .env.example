# Copy to .env and fill in values before running

# Server
PORT=3000
NODE_ENV=production

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://chronicle.local,http://localhost:3000

# Database & vault paths (defaults work for Docker)
DB_PATH=/data/chronicle.db
VAULT_PATH=/data/vault

# GM account username (created on first run if not exists)
GM_USERNAME=dungeonmaster
